{
  "expo": {
    "name": "Hello Sara",
    "slug": "hellosara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.completepromptpdf.jvd1n5",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Talk with Sara using your voice",
        "NSSpeechRecognitionUsageDescription": "Convert your voice to text",
        "NSCameraUsageDescription": "Scan documents and receipts",
        "NSPhotoLibraryUsageDescription": "Attach photos and images",
        "NSCalendarsUsageDescription": "Read and create events",
        "NSContactsUsageDescription": "Call or message the people you know",
        "NSLocationWhenInUseUsageDescription": "Weather and nearby suggestions"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.completepromptpdf.jvd1n5",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.SEND_SMS",
        "android.permission.READ_SMS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FLASHLIGHT",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.SET_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Talk with Sara using your voice",
          "speechRecognitionPermission": "Convert your voice to text"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Sara adds reminders and events to your calendar."
        }
      ],
      "expo-web-browser",
      "./plugins/hello-sara-native/app.plugin.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
